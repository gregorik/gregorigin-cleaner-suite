<Window x:Class="GregOriginSuiteApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="GregOrigin Cleaner Suite" Height="760" Width="1050" 
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI Light"
        Background="{DynamicResource WindowBackground}"
        Closing="Window_Closing">
    
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#F3F9FF"/>
        <SolidColorBrush x:Key="TextForeground" Color="#333333"/>
        <SolidColorBrush x:Key="ListBackground" Color="White"/>
        <SolidColorBrush x:Key="TextBoxBackground" Color="White"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#004E8C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#ADD8E6"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/> 
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource ListBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <!-- GridView Header Style for Dark Mode -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TabItem Custom Template -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ListBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ListBackground}"/>
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>
        
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,15,10"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TASKBAR ICON -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="/Icon.ico"
                        ToolTipText="GregOrigin Cleaner Suite"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open Suite" Click="TrayIcon_Open_Click"/>
                    <MenuItem Header="Exit" Click="TrayIcon_Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- SUBTLE HEADER -->
        <Border Grid.Row="0" Background="Transparent" Padding="20,15,20,0">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image Source="/Logo.png" Height="28" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="GregOrigin" Foreground="{DynamicResource TextForeground}" FontSize="18" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Text=" Cleaner Suite Pro" Foreground="{DynamicResource TextForeground}" FontSize="14" VerticalAlignment="Bottom" Margin="5,0,0,1" Opacity="0.5"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button Name="ThemeToggleBtn" Content="Toggle Theme" Background="Transparent" Foreground="{DynamicResource TextForeground}" FontSize="13" FontWeight="Normal" Opacity="0.6" Click="ThemeToggleBtn_Click" Margin="0,0,10,0" Padding="5,2"/>
                    <Button Name="SiteBtn" Content="gregorigin.com &#x2197;" Background="Transparent" Foreground="#0078D7" FontSize="13" FontWeight="SemiBold" Opacity="0.8" Click="SiteBtn_Click" Padding="5,2"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN TABS -->
        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Margin="10">
            
            <!-- TAB 1: UNINSTALLER -->
            <TabItem Header="Uninstall">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBox Name="SearchBox" Grid.Row="0" Height="35" VerticalContentAlignment="Center" 
                             Padding="5" Margin="0,0,0,10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                             Text="Search installed apps..." GotFocus="SearchBox_GotFocus" TextChanged="SearchBox_TextChanged"/>
                    
                    <ListView Name="AppList" Grid.Row="1" SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="380" DisplayMemberBinding="{Binding DisplayName}"/>
                                <GridViewColumn Header="Publisher" Width="220" DisplayMemberBinding="{Binding Publisher}"/>
                                <GridViewColumn Header="Ver" Width="100" DisplayMemberBinding="{Binding DisplayVersion}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    
                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <Label Name="StatusLabel" Content="Ready" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="RefreshBtn" Content="Refresh" Background="#666" Click="RefreshBtn_Click"/>
                            <CheckBox Name="chkForceScrub" Content="Deep Scrub Remnants" IsChecked="False" VerticalAlignment="Center" Margin="10,0,10,0"/>
                            <Button Name="UninstallBtn" Content="Uninstall Selected" Background="#C42B1C" Click="UninstallBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: CLEANER -->
            <TabItem Header="Clean">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Advanced System Cleaning" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                    
                    <Border Grid.Row="1" Background="{DynamicResource ListBackground}" Padding="15" CornerRadius="5">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Basic -->
                            <CheckBox Name="chkWinTemp" Content="Windows Temp" IsChecked="True"/>
                            <CheckBox Name="chkUserTemp" Content="User Temp" IsChecked="True"/>
                            <CheckBox Name="chkRecycle" Content="Empty Recycle Bin" IsChecked="False"/>
                            
                            <!-- Browsers -->
                            <CheckBox Name="chkEdge" Content="Edge Cache" IsChecked="True"/>
                            <CheckBox Name="chkChrome" Content="Chrome Cache" IsChecked="True"/>
                            <CheckBox Name="chkBrowserSqlite" Content="Browser Cookies/History (SQLite)" IsChecked="False" Foreground="#C42B1C"/>
                            
                            <!-- Advanced -->
                            <CheckBox Name="chkPrefetch" Content="Prefetch" IsChecked="False"/>
                            <CheckBox Name="chkSoftwareDist" Content="WinUpdate Cache" IsChecked="False"/>
                            <CheckBox Name="chkSystemRestore" Content="Old System Restores" IsChecked="False"/>
                        </WrapPanel>
                    </Border>

                    <TextBox Name="LogBox" Grid.Row="2" Margin="0,15,0,15" IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" Background="{DynamicResource ListBackground}" Foreground="{DynamicResource TextForeground}" BorderThickness="0" 
                             Padding="10" FontFamily="Consolas" />

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Name="ScanBtn" Content="Analyze" Background="#0078D7" Click="ScanBtn_Click"/>
                        <Button Name="CleanBtn" Content="Run Cleaner" Background="#28A745" Click="CleanBtn_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3: UPDATE & INSTALL -->
            <TabItem Header="Software">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Winget Software Manager" FontSize="20" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox Name="WingetSearchBox" Width="200" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0" Padding="5" Text="Search apps to install..."/>
                            <Button Name="WingetSearchBtn" Content="Search &amp; Install" Background="#0078D7" Click="WingetSearchBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                    
                    <ListView Name="UpdateList" Grid.Row="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Application" Width="250" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Package ID" Width="260" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Current" Width="110" DisplayMemberBinding="{Binding Current}"/>
                                <GridViewColumn Header="Newest Available" Width="120" DisplayMemberBinding="{Binding Available}"/>
                                <GridViewColumn Header="Source" Width="90" DisplayMemberBinding="{Binding Source}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="2" Margin="0,15,0,0">
                        <Label Name="UpdateStatus" Content="Check for updates to begin." Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="CheckUpdateBtn" Content="Check Updates" Click="CheckUpdateBtn_Click"/>
                            <Button Name="UpdateSelectedBtn" Content="Update Selected" Background="#E0A800" Click="UpdateSelectedBtn_Click"/>
                            <Button Name="UpdateAllBtn" Content="Update All" Background="#28A745" Click="UpdateAllBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- TAB 4: STARTUP APPS -->
            <TabItem Header="Startup">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Manage Startup Applications" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                    
                    <ListView Name="StartupList" Grid.Row="1" SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Command" Width="300" DisplayMemberBinding="{Binding Command}"/>
                                <GridViewColumn Header="Location" Width="200" DisplayMemberBinding="{Binding Location}"/>
                                <GridViewColumn Header="State" Width="100" DisplayMemberBinding="{Binding State}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="2" Margin="0,15,0,0">
                        <Label Name="StartupStatus" Content="Ready" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="RefreshStartupBtn" Content="Refresh" Background="#666" Click="RefreshStartupBtn_Click"/>
                            <Button Name="ToggleStartupBtn" Content="Toggle Enable/Disable" Background="#E0A800" Click="ToggleStartupBtn_Click"/>
                            <Button Name="DeleteStartupBtn" Content="Delete Selected" Background="#C42B1C" Click="DeleteStartupBtn_Click"/>
                            <Button Name="RestoreStartupBtn" Content="Restore Backups" Background="#0078D7" Click="RestoreStartupBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>
            
            <!-- TAB 5: OPTIMIZE -->
            <TabItem Header="Optimize">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="System Services &amp; Tuning" FontSize="22" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="NetworkFlushBtn" Content="Network &amp; DNS Flush" Background="{DynamicResource PrimaryColor}" Click="NetworkFlushBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                    
                    <ListView Name="ServicesList" Grid.Row="1" SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Service Name" Width="160" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Display Name" Width="240" DisplayMemberBinding="{Binding DisplayName}"/>
                                <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Startup Type" Width="100" DisplayMemberBinding="{Binding StartupType}"/>
                                <GridViewColumn Header="Default" Width="90" DisplayMemberBinding="{Binding SafeDefaultStartupType}"/>
                                <GridViewColumn Header="Allowlist Reason" Width="280" DisplayMemberBinding="{Binding AllowlistReason}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="2" Margin="0,15,0,0">
                        <Label Name="OptimizeStatus" Content="Ready" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="RefreshServicesBtn" Content="Refresh" Background="#666" Click="RefreshServicesBtn_Click"/>
                            <Button Name="ToggleServiceBtn" Content="Toggle Start/Stop" Background="#E0A800" Click="ToggleServiceBtn_Click"/>
                            <Button Name="DisableServiceBtn" Content="Set Disabled" Background="#C42B1C" Click="DisableServiceBtn_Click"/>
                            <Button Name="RestoreServicesBtn" Content="Restore Backups" Background="#0078D7" Click="RestoreServicesBtn_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- TAB 6: HARDWARE & TELEMETRY -->
            <TabItem Header="Hardware">
                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="System Telemetry" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                        <Border Background="{DynamicResource ListBackground}" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Name="TxtCpu" Text="CPU: Scanning..." FontSize="16" Margin="0,5"/>
                                <TextBlock Name="TxtRam" Text="RAM: Scanning..." FontSize="16" Margin="0,5"/>
                                <TextBlock Name="TxtGpu" Text="GPU: Scanning..." FontSize="16" Margin="0,5"/>
                                <TextBlock Name="TxtOs" Text="OS: Scanning..." FontSize="16" Margin="0,5"/>
                            </StackPanel>
                        </Border>
                        <Button Name="RefreshHardwareBtn" Content="Refresh Telemetry" Background="#0078D7" Click="RefreshHardwareBtn_Click" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Storage Health (WMI Status)" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                        <ListView Name="SmartList" Height="150" Margin="0,0,0,15">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Drive" Width="120" DisplayMemberBinding="{Binding Drive}"/>
                                    <GridViewColumn Header="Model" Width="180" DisplayMemberBinding="{Binding Model}"/>
                                    <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        
                        <TextBlock Text="Large File Scanner" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,15"/>
                        <Button Name="ScanLargeFilesBtn" Content="Scan C:\ for Top 50 Large Files" Background="#E0A800" Click="ScanLargeFilesBtn_Click" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 7: DEFRAG -->
            <TabItem Header="Defrag">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="State-of-the-Art Disk Optimization" FontSize="22" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Target Drive: " VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}" Margin="0,0,5,0" />
                            <ComboBox Name="DefragDriveCombo" Width="70" Margin="0,0,15,0" VerticalContentAlignment="Center" Background="{DynamicResource ListBackground}" Foreground="{DynamicResource TextForeground}" />
                            <CheckBox Name="chkSsdTrim" Content="SSD TRIM (Retrim)" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <CheckBox Name="chkBootDefrag" Content="Boot Sector Optimize" IsChecked="False" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        </StackPanel>
                    </DockPanel>
                    
                    <TextBox Name="DefragLogBox" Grid.Row="1" IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" Background="{DynamicResource ListBackground}" Foreground="{DynamicResource TextForeground}" BorderThickness="0" 
                             Padding="10" FontFamily="Consolas" Margin="0,0,0,10" />

                    <DockPanel Grid.Row="2" Margin="0,5,0,0">
                        <Label Name="DefragStatus" Content="Ready" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="AnalyzeDriveBtn" Content="Analyze Drive" Background="#0078D7" Click="AnalyzeDriveBtn_Click"/>
                            <Button Name="OptimizeDriveBtn" Content="Optimize &amp; Defrag" Background="#28A745" Click="OptimizeDriveBtn_Click"/>
                            <Button Name="CancelDefragBtn" Content="Cancel" Background="#C42B1C" Click="CancelDefragBtn_Click" IsEnabled="False"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- TAB 8: SETTINGS -->
            <TabItem Header="Options">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Application Settings" FontSize="22" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,20"/>
                    
                    <Border Grid.Row="1" Background="{DynamicResource ListBackground}" Padding="20" CornerRadius="5" VerticalAlignment="Top" HorizontalAlignment="Left" MinWidth="400">
                        <StackPanel>
                            <CheckBox Name="chkSkipConfirmations" Content="Skip Warning/Confirmation Prompts (Advanced)" Checked="ChkSkipConfirmations_CheckedChanged" Unchecked="ChkSkipConfirmations_CheckedChanged" Margin="0,0,0,15"/>
                            <TextBlock Text="When enabled, actions like 'Uninstall' or 'Clean' will immediately execute without asking 'Are you sure?'." Foreground="{DynamicResource TextForeground}" Opacity="0.7" FontSize="12" Margin="25,-10,0,20" TextWrapping="Wrap"/>
                            
                            <TextBlock Text="Note: The Light/Dark theme preference is automatically saved when toggled via the header button." Foreground="{DynamicResource TextForeground}" Opacity="0.7" FontSize="12" FontStyle="Italic" Margin="0,0,0,15"/>

                            <Separator Margin="0,15,0,15" Background="{DynamicResource BorderColor}" />

                            <TextBlock Text="Disclaimer" FontSize="16" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <TextBlock Text="The GregOrigin Cleaner Suite Pro modifies startup entries, deletes selected temporary files, and interacts with Microsoft tools such as Winget, VSS, services, and Defrag. Privileged actions prompt for administrator restart when needed. Cleanup writes a dry-run audit before deletion, but advanced tuning features should still be used carefully." Foreground="{DynamicResource TextForeground}" Opacity="0.7" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <Separator Margin="0,0,0,15" Background="{DynamicResource BorderColor}" />

                            <TextBlock Text="About" FontSize="16" Foreground="{DynamicResource PrimaryColor}" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <TextBlock Text="Created by Andras Gregori @ GregOrigin, (c) 2026" Foreground="{DynamicResource TextForeground}" Opacity="0.8" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
